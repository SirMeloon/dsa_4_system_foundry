<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100"/>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Name"/></h1>
      {{!-- The grid classes are defined in scss/global/_grid.scss. To use,
      use both the "grid" and "grid-Ncol" class where "N" can be any number
      from 1 to 12 and will create that number of columns.  --}}
      <div class="resources grid grid-3col">

        {{!-- "flex-group-center" is also defined in the _grid.scss file
        and it will add a small amount of padding, a border, and will
        center all of its child elements content and text. --}}
        <div class="resource flex-group-center">
          <label for="system.lebensenergie.value" class="resource-label">lebensenergie</label>
          <div class="resource-content flexrow flex-center flex-between">
          <input type="text" name="system.lebensenergie.value" value="{{system.lebensenergie.value}}" data-dtype="Number"/>
          <span> / </span>
          <input type="text" name="system.lebensenergie.max" value="{{system.lebensenergie.max}}" data-dtype="Number"/>
          </div>
        </div>

        <div class="resource flex-group-center">
          <label for="system.power.value" class="resource-label">Power</label>
          <div class="resource-content flexrow flex-center flex-between">
          <input type="text" name="system.power.value" value="{{system.power.value}}" data-dtype="Number"/>
          <span> / </span>
          <input type="text" name="system.power.max" value="{{system.power.max}}" data-dtype="Number"/>
          </div>
        </div>

        <div class="resource flex-group-center">
          <label for="system.attributes.level.value" class="resource-label">Level</label>
          <div class="resource-content flexrow flex-center flex-between">
          <input type="text" name="system.attributes.level.value" value="{{system.attributes.level.value}}" data-dtype="Number"/>
          </div>
        </div>

      </div>
    </div>
  </header>

  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    {{!-- Default tab is specified in actor-sheet.mjs --}}
    <a class="item" data-tab="features">{{localize "DSA.Actor.Tabs.Features"}}</a>
    <a class="item" data-tab="talents">{{localize "DSA.Actor.Tabs.Talents"}}</a>
    <a class="item" data-tab="description">{{localize "DSA.Actor.Tabs.Description"}}</a>
    <a class="item" data-tab="items">{{localize "DSA.Actor.Tabs.Items"}}</a>
    <a class="item" data-tab="spells">{{localize "DSA.Actor.Tabs.Spells"}}</a>
    <a class="item" data-tab="effects">{{localize "DSA.Actor.Tabs.Effects"}}</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Owned Features Tab --}}
    <div class="tab features" data-group="primary" data-tab="features">
      <section class="grid grid-3col">
        <aside class="sidebar">

          {{!-- The grid classes are defined in scss/global/_grid.scss. To use,
          use both the "grid" and "grid-Ncol" class where "N" can be any number
          from 1 to 12 and will create that number of columns.  --}}
          <div class="abilities flexcol">
            {{#each system.abilities as |ability key|}}
            <div class="ability flexrow flex-group-center">
              <label for="system.abilities.{{key}}.value" class="resource-label rollable flexlarge align-left" data-roll="d20" data-label="{{localize (lookup @root.config.abilities key)}}">{{localize (lookup @root.config.abilities key)}}</label>
              <input type="text" name="system.abilities.{{key}}.value" value="{{ability.value}}" data-dtype="Number"/>
              
            </div>
            {{/each}}
          </div>
          <div class="proficiencies flexcol">
            <h3>{{localize "DSA.Proficiencies.Label"}}</h3>

            <div class="proficiency-group">
              <div class="proficiency-header flexrow flex-group-center">
                <label class="resource-label flexlarge align-left">{{localize "DSA.Proficiencies.Weapons"}}</label>
                <a class="proficiency-create" data-proficiency="weapons" title="{{localize "DSA.Proficiencies.AddWeapon"}}"><i class="fas fa-plus"></i></a>
              </div>
              {{#each system.proficiencies.weapons as |weapon index|}}
              <div class="proficiency flexrow flex-group-center">
                <input class="proficiency-input" type="text" value="{{weapon}}" data-proficiency="weapons" data-index="{{index}}"/>
                <a class="proficiency-delete" data-proficiency="weapons" data-index="{{index}}" title="{{localize "DSA.Proficiencies.Remove"}}"><i class="fas fa-trash"></i></a>
              </div>
              {{/each}}
            </div>

            <div class="proficiency-group">
              <div class="proficiency-header flexrow flex-group-center">
                <label class="resource-label flexlarge align-left">{{localize "DSA.Proficiencies.Skills"}}</label>
                <a class="proficiency-create" data-proficiency="skills" title="{{localize "DSA.Proficiencies.AddSkill"}}"><i class="fas fa-plus"></i></a>
              </div>
              {{#each system.proficiencies.skills as |skill index|}}
              <div class="proficiency flexrow flex-group-center">
                <input class="proficiency-input" type="text" value="{{skill}}" data-proficiency="skills" data-index="{{index}}"/>
                <a class="proficiency-delete" data-proficiency="skills" data-index="{{index}}" title="{{localize "DSA.Proficiencies.Remove"}}"><i class="fas fa-trash"></i></a>
              </div>
              {{/each}}
            </div>
          </div>
        </aside>

        {{!-- For the main features list, span the right two columns --}}
        <section class="main grid-span-2">
          {{!-- This is a Handlebars partial. They're stored in the `/parts` folder next to this sheet, and defined in module/helpers/templates.mjs --}}
          {{> "systems/dsa_4_system_foundry/templates/actor/parts/actor-features.hbs"}}
        </section>

      </section>
    </div>

    <div class="tab talents" data-group="primary" data-tab="talents">
      {{> "systems/dsa_4_system_foundry/templates/actor/parts/actor-talents.hbs"}}
    </div>

    {{!-- Biography Tab --}}
    <div class="tab biography" data-group="primary" data-tab="description">
      {{!-- Editors must receive enriched text data from getData to properly handle rolls --}}
      {{editor enrichedBiography target="system.biography" engine="prosemirror" button=true editable=editable}}
    </div>

    {{!-- Owned Items Tab --}}
    <div class="tab items" data-group="primary" data-tab="items">
       {{> "systems/dsa_4_system_foundry/templates/actor/parts/actor-items.hbs"}}
    </div>

    {{!-- Owned Spells Tab --}}
    <div class="tab spells" data-group="primary" data-tab="spells">
      {{> "systems/dsa_4_system_foundry/templates/actor/parts/actor-spells.hbs"}}
    </div>

    {{!-- Active Effects Tab --}}
    <div class="tab effects flexcol" data-group="primary" data-tab="effects">
      {{> "systems/dsa_4_system_foundry/templates/actor/parts/actor-effects.hbs"}}
    </div>

  </section>
</form>
