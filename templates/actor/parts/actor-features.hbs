<div class='actor-feature-layout'>
  <section class='actor-feature-summary'>
    <header class='items-header flexrow'>
      <div class='item-name'>{{localize 'DSA.Actor.Features.Summary'}}</div>
    </header>
    <div class='actor-feature-summary-body'>
      {{#if featureAbilityBonuses.length}}
        <ul class='actor-rule-list actor-bonus-list'>
          {{#each featureAbilityBonuses as |bonus|}}
            <li><strong>{{bonus.label}}</strong><span>{{bonus.value}}</span></li>
          {{/each}}
        </ul>
      {{/if}}
      {{#if featureResourceBonuses.length}}
        <ul class='actor-rule-list actor-bonus-list'>
          {{#each featureResourceBonuses as |bonus|}}
            <li>
              <strong>{{bonus.key}}</strong>
              {{#if bonus.value}}<span>{{bonus.value}}</span>{{/if}}
              {{#if bonus.max}}<span>max {{bonus.max}}</span>{{/if}}
            </li>
          {{/each}}
        </ul>
      {{/if}}
      {{#if featureSummary.derivedRules.length}}
        <ul class='actor-rule-list'>
          {{#each featureSummary.derivedRules as |rule|}}
            <li>
              <strong>{{rule.source}}</strong>
              <span>{{rule.typeLabel}}</span>
              {{#if rule.target}}<span>{{rule.target}}</span>{{/if}}
              {{#if rule.mode}}<span>{{rule.mode}}</span>{{/if}}
              {{#if rule.value}}<span>{{rule.value}}</span>{{/if}}
              {{#if rule.note}}<span>{{rule.note}}</span>{{/if}}
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p class='actor-empty-state'>{{localize 'DSA.Actor.Features.NoRules'}}</p>
      {{/if}}
    </div>
  </section>

  {{#if hasFeatures}}
    <div class='actor-feature-groups'>
      <section class='actor-feature-group'>
        <header class='items-header flexrow'>
          <div class='item-name'>{{localize 'DSA.Actor.Features.Advantage'}}</div>
          <div class='item-controls'>
            <a class='item-control item-create' title='Create item' data-type='feature'>
              <i class='fas fa-plus'></i>
              {{localize 'DOCUMENT.New' type="feature"}}
            </a>
          </div>
        </header>
        <ol class='items-list'>
          {{#each featureBuckets.advantage as |item|}}
            <li class='item flexrow' data-item-id='{{item._id}}'>
              <div class='item-name'>
                <div class='item-image'>
                  <a class='rollable' data-roll-type='item'>
                    <img src='{{item.img}}' title='{{item.name}}' width='24' height='24' />
                  </a>
                </div>
                <h4>{{item.name}}</h4>
              </div>
              <div class='item-controls'>
                <a class='item-control item-edit' title='{{localize "DOCUMENT.Edit" type="feature"}}'><i class='fas fa-edit'></i></a>
                <a class='item-control item-delete' title='{{localize "DOCUMENT.Delete" type="feature"}}'><i class='fas fa-trash'></i></a>
              </div>
            </li>
          {{/each}}
        </ol>
      </section>

      <section class='actor-feature-group'>
        <header class='items-header flexrow'>
          <div class='item-name'>{{localize 'DSA.Actor.Features.Disadvantage'}}</div>
        </header>
        <ol class='items-list'>
          {{#each featureBuckets.disadvantage as |item|}}
            <li class='item flexrow' data-item-id='{{item._id}}'>
              <div class='item-name'>
                <div class='item-image'>
                  <a class='rollable' data-roll-type='item'>
                    <img src='{{item.img}}' title='{{item.name}}' width='24' height='24' />
                  </a>
                </div>
                <h4>{{item.name}}</h4>
              </div>
              <div class='item-controls'>
                <a class='item-control item-edit' title='{{localize "DOCUMENT.Edit" type="feature"}}'><i class='fas fa-edit'></i></a>
                <a class='item-control item-delete' title='{{localize "DOCUMENT.Delete" type="feature"}}'><i class='fas fa-trash'></i></a>
              </div>
            </li>
          {{/each}}
        </ol>
      </section>

      <section class='actor-feature-group actor-feature-group-wide'>
        <header class='items-header flexrow'>
          <div class='item-name'>{{localize 'DSA.Actor.Features.SpecialAbility'}}</div>
        </header>
        <ol class='items-list'>
          {{#each featureBuckets.specialAbility as |item|}}
            <li class='item flexrow' data-item-id='{{item._id}}'>
              <div class='item-name'>
                <div class='item-image'>
                  <a class='rollable' data-roll-type='item'>
                    <img src='{{item.img}}' title='{{item.name}}' width='24' height='24' />
                  </a>
                </div>
                <h4>{{item.name}}</h4>
              </div>
              <div class='item-controls'>
                <a class='item-control item-edit' title='{{localize "DOCUMENT.Edit" type="feature"}}'><i class='fas fa-edit'></i></a>
                <a class='item-control item-delete' title='{{localize "DOCUMENT.Delete" type="feature"}}'><i class='fas fa-trash'></i></a>
              </div>
            </li>
          {{/each}}
          {{#each featureBuckets.uncategorized as |item|}}
            <li class='item flexrow' data-item-id='{{item._id}}'>
              <div class='item-name'>
                <div class='item-image'>
                  <a class='rollable' data-roll-type='item'>
                    <img src='{{item.img}}' title='{{item.name}}' width='24' height='24' />
                  </a>
                </div>
                <h4>{{item.name}}</h4>
              </div>
              <div class='item-controls'>
                <a class='item-control item-edit' title='{{localize "DOCUMENT.Edit" type="feature"}}'><i class='fas fa-edit'></i></a>
                <a class='item-control item-delete' title='{{localize "DOCUMENT.Delete" type="feature"}}'><i class='fas fa-trash'></i></a>
              </div>
            </li>
          {{/each}}
        </ol>
      </section>
    </div>
  {{else}}
    <div class='actor-feature-dropzone'>
      {{localize 'DSA.Actor.Features.NoFeatures'}}
    </div>
  {{/if}}
</div>
