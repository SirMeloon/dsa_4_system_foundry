<ol class='items-list talent-list'>
  {{#each talentsByGroup as |talents group|}}
    <li class='item flexrow items-header'>
      <div class='item-name'>{{group}}</div>
      <div class='item-prop talent-prop'>{{localize 'DSA.Talent.Fields.AdvancementLetter'}}</div>
      <div class='item-prop talent-prop'>{{localize 'DSA.Talent.Fields.EffectiveEncumbrance'}}</div>
      <div class='item-prop talent-taw'>{{localize 'DSA.Talent.Fields.Taw'}}</div>
      <div class='item-controls'>
        <a
          class='item-control item-create'
          title='{{localize "DOCUMENT.Create" type="talent"}}'
          data-type='talent'
        >
          <i class='fas fa-plus'></i>
          {{localize 'DOCUMENT.New' type="talent"}}
        </a>
      </div>
    </li>
    {{#each talents as |item|}}
      <li class='item flexrow' data-item-id='{{item._id}}'>
        <div class='item-name'>
          <div class='item-image'>
            <a class='rollable' data-roll-type='item'>
              <img
                src='{{item.img}}'
                title='{{item.name}}'
                width='24'
                height='24'
              />
            </a>
          </div>
          <div class='talent-name-block'>
            <h4>{{item.name}}</h4>
            {{#if item.system.basicTalent}}
              <small>{{localize 'DSA.Talent.Fields.BasicTalent'}}</small>
            {{/if}}
          </div>
        </div>
        <div class='item-prop talent-prop'>{{item.system.advancementLetter}}</div>
        <div class='item-prop talent-prop'>{{item.system.effectiveEncumbrance}}</div>
        <div class='item-prop talent-taw'>
          <input
            class='talent-taw-input'
            type='number'
            value='{{item.system.taw}}'
            step='1'
            data-item-id='{{item._id}}'
          />
        </div>
        <div class='item-controls'>
          <a
            class='item-control item-edit'
            title='{{localize "DOCUMENT.Edit" type="talent"}}'
          >
            <i class='fas fa-edit'></i>
          </a>
          <a
            class='item-control item-delete'
            title='{{localize "DOCUMENT.Delete" type="talent"}}'
          >
            <i class='fas fa-trash'></i>
          </a>
        </div>
      </li>
    {{/each}}
  {{/each}}
</ol>
