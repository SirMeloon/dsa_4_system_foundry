            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.knowledgeTalents"}}</h3><textarea name="culture.knowledgeTalentsText">{{culture.knowledgeTalentsText}}</textarea><h3>{{localize "DSA41.Culture.scriptsLanguagesTalents"}}</h3><textarea name="culture.scriptsLanguagesTalentsText">{{culture.scriptsLanguagesTalentsText}}</textarea><h3>{{localize "DSA41.Culture.craftTalents"}}</h3><textarea name="culture.craftTalentsText">{{culture.craftTalentsText}}</textarea></section>
        </div>
        {{else}}
        <div class="dsa41-two-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.lifestyle"}}</h3><p>{{system.lifestyle}}</p></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.worldviewFaith"}}</h3><p>{{system.worldviewFaith}}</p></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.customs"}}</h3><p>{{system.customs}}</p></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.clothingWeapons"}}</h3><p>{{system.clothingWeapons}}</p></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.selfImage"}}</h3><p>{{system.selfImage}}</p></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.languageNames"}}</h3><p>{{system.languageNames}}</p></section>
        </div>
        <div class="dsa41-three-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.modifications"}}</h3><ul class="dsa41-list">{{#each system.modifications}}<li>{{this}}</li>{{/each}}</ul><h3>{{localize "DSA41.Culture.specialAbilities"}}</h3><ul class="dsa41-list">{{#each system.specialAbilities}}<li>{{this}}</li>{{/each}}</ul></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.recommendedAdvantages"}}</h3><ul class="dsa41-list">{{#each system.recommendedAdvantages}}<li>{{this}}</li>{{/each}}</ul><h3>{{localize "DSA41.Culture.recommendedDisadvantages"}}</h3><ul class="dsa41-list">{{#each system.recommendedDisadvantages}}<li>{{this}}</li>{{/each}}</ul></section>
