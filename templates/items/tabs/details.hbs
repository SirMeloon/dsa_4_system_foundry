<section class="dsa41-tab-panel {{#unless (eq activeTab 'details')}}is-hidden{{/unless}} {{#if isSpecies}}dsa41-species-overlay dsa41-species-details-overlay{{/if}}">
    {{#if isSpecies}}
    <section class="dsa41-panel">
        <h3>{{localize "DSA41.Species.identifier"}}</h3>
        {{#if editable}}
        <input name="system.identifier" type="text" value="{{system.identifier}}" />
        {{else}}
        <p>{{system.identifier}}</p>
        {{/if}}
    </section>
    {{else}}
    {{#if isWeapon}}
    <section class="dsa41-panel">
        <div class="dsa41-stats-grid">
            <label><span>{{localize "DSA41.Weapon.group"}}</span><select name="system.group">{{selectOptions config.weaponGroups selected=system.group localize=true}}</select></label>
            <label><span>{{localize "DSA41.Weapon.damage"}}</span><input name="system.damage" type="text" value="{{system.damage}}" /></label>
            <label><span>{{localize "DSA41.Weapon.attackModifier"}}</span><input name="system.attackModifier" type="number" value="{{system.attackModifier}}" /></label>
            <label><span>{{localize "DSA41.Weapon.parryModifier"}}</span><input name="system.parryModifier" type="number" value="{{system.parryModifier}}" /></label>
            <label><span>{{localize "DSA41.Weapon.initiativeModifier"}}</span><input name="system.initiativeModifier" type="number" value="{{system.initiativeModifier}}" /></label>
            <label><span>{{localize "DSA41.Weapon.range"}}</span><input name="system.range" type="text" value="{{system.range}}" /></label>
            <label><span>{{localize "DSA41.Weapon.weight"}}</span><input name="system.weight" type="text" value="{{system.weight}}" /></label>
        </div>
    </section>
    {{/if}}

    {{#if isSkill}}
    <section class="dsa41-panel">
        <div class="dsa41-stats-grid">
            <label><span>{{localize "DSA41.Skill.group"}}</span><input name="system.group" type="text" value="{{system.group}}" /></label>
            <label><span>{{localize "DSA41.Skill.complexity"}}</span><input name="system.complexity" type="text" value="{{system.complexity}}" /></label>
            <label><span>{{localize "DSA41.Skill.probe"}} 1</span><select name="system.probe.0">{{selectOptions config.characteristics selected=system.probe.[0] localize=true}}</select></label>
            <label><span>{{localize "DSA41.Skill.probe"}} 2</span><select name="system.probe.1">{{selectOptions config.characteristics selected=system.probe.[1] localize=true}}</select></label>
            <label><span>{{localize "DSA41.Skill.probe"}} 3</span><select name="system.probe.2">{{selectOptions config.characteristics selected=system.probe.[2] localize=true}}</select></label>
        </div>
    </section>
    {{/if}}

    {{#if isSpecies}}
        {{#if isEditMode}}
        <div class="dsa41-two-column">
            <section class="dsa41-panel">
                <h3>{{localize "DSA41.Species.appearanceDescription"}}</h3>
                <textarea name="system.appearance">{{system.appearance}}</textarea>
            </section>
            <section class="dsa41-panel">
                <h3>{{localize "DSA41.Species.hairColor"}}</h3>
                <textarea name="species.hairColorsText">{{species.hairColorsText}}</textarea>
                <h3>{{localize "DSA41.Species.eyeColor"}}</h3>
                <textarea name="species.eyeColorsText">{{species.eyeColorsText}}</textarea>
            </section>
        </div>
        <section class="dsa41-panel">
            <div class="dsa41-stats-grid">
                <label><span>{{localize "DSA41.Species.base"}}</span><input name="system.height.base" type="text" value="{{system.height.base}}" /></label>
                <label><span>{{localize "DSA41.Species.diceCount"}}</span><input name="system.height.diceCount" type="number" value="{{system.height.diceCount}}" /></label>
                <label><span>{{localize "DSA41.Species.diceFaces"}}</span><input name="system.height.diceFaces" type="number" value="{{system.height.diceFaces}}" /></label>
                <label><span>{{localize "DSA41.Species.step"}}</span><input name="system.height.step" type="text" value="{{system.height.step}}" /></label>
                <label><span>{{localize "DSA41.Species.unit"}}</span><input name="system.height.unit" type="text" value="{{system.height.unit}}" /></label>
                <label><span>{{localize "DSA41.Species.formula"}}</span><input name="system.height.formula" type="text" value="{{system.height.formula}}" /></label>
                <label><span>{{localize "DSA41.Species.weight"}}</span><input name="system.weight.formula" type="text" value="{{system.weight.formula}}" /></label>
                <label><span>{{localize "DSA41.Species.unit"}}</span><input name="system.weight.unit" type="text" value="{{system.weight.unit}}" /></label>
            </div>
        </section>
        <section class="dsa41-panel">
            <div class="dsa41-stats-grid">
                {{#each system.modifiers.characteristics as |value key|}}
                <label><span>{{localize (lookup ../config.characteristics key)}}</span><input name="system.modifiers.characteristics.{{key}}" type="number" value="{{value}}" /></label>
                {{/each}}
                <label><span>{{localize "DSA41.Species.lifePointsModifier"}}</span><input name="system.modifiers.lifePoints" type="number" value="{{system.modifiers.lifePoints}}" /></label>
                <label><span>{{localize "DSA41.Species.enduranceModifier"}}</span><input name="system.modifiers.endurance" type="number" value="{{system.modifiers.endurance}}" /></label>
                <label><span>{{localize "DSA41.Species.astralPointsModifier"}}</span><input name="system.modifiers.astralPoints" type="number" value="{{system.modifiers.astralPoints}}" /></label>
                <label><span>{{localize "DSA41.Species.magicResistanceModifier"}}</span><input name="system.modifiers.magicResistance" type="number" value="{{system.modifiers.magicResistance}}" /></label>
            </div>
        </section>
        <div class="dsa41-two-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.allowedCultures"}}</h3><textarea name="species.allowedCulturesText">{{species.allowedCulturesText}}</textarea></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.grantedTalents"}}</h3><textarea name="species.grantedTalentsText">{{species.grantedTalentsText}}</textarea></section>
        </div>
        <div class="dsa41-three-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.automaticAdvantages"}}</h3><textarea name="species.automaticAdvantagesText">{{species.automaticAdvantagesText}}</textarea><h3>{{localize "DSA41.Species.automaticDisadvantages"}}</h3><textarea name="species.automaticDisadvantagesText">{{species.automaticDisadvantagesText}}</textarea></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.recommendedAdvantages"}}</h3><textarea name="species.recommendedAdvantagesText">{{species.recommendedAdvantagesText}}</textarea><h3>{{localize "DSA41.Species.recommendedDisadvantages"}}</h3><textarea name="species.recommendedDisadvantagesText">{{species.recommendedDisadvantagesText}}</textarea></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.unsuitableAdvantages"}}</h3><textarea name="species.unsuitableAdvantagesText">{{species.unsuitableAdvantagesText}}</textarea><h3>{{localize "DSA41.Species.unsuitableDisadvantages"}}</h3><textarea name="species.unsuitableDisadvantagesText">{{species.unsuitableDisadvantagesText}}</textarea></section>
        </div>
        {{else}}
        <div class="dsa41-two-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.appearanceDescription"}}</h3><p>{{system.appearance}}</p></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.hairColor"}}</h3><ul class="dsa41-list">{{#each system.hairColors}}<li>{{min}}-{{max}}: {{label}}</li>{{/each}}</ul><h3>{{localize "DSA41.Species.eyeColor"}}</h3><ul class="dsa41-list">{{#each system.eyeColors}}<li>{{min}}-{{max}}: {{label}}</li>{{/each}}</ul></section>
        </div>
        <div class="dsa41-three-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.height"}}</h3><p>{{system.height.formula}}</p></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.weight"}}</h3><p>{{system.weight.formula}} {{system.weight.unit}}</p></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.allowedCultures"}}</h3><ul class="dsa41-list">{{#each system.allowedCultures}}<li>{{this}}</li>{{/each}}</ul></section>
        </div>
        <div class="dsa41-two-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.characteristicModifiers"}}</h3><ul class="dsa41-list">{{#each species.characteristicModifiers}}<li>{{label}}: {{value}}</li>{{/each}}{{#each species.scalarModifiers}}<li>{{label}}: {{value}}</li>{{/each}}</ul></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.grantedTalents"}}</h3><ul class="dsa41-list">{{#each species.grantedTalents}}<li>{{name}}: {{value}}</li>{{/each}}</ul></section>
        </div>
        <div class="dsa41-three-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.automaticAdvantages"}}</h3><ul class="dsa41-list">{{#each system.automaticAdvantages}}<li>{{this}}</li>{{/each}}</ul><h3>{{localize "DSA41.Species.automaticDisadvantages"}}</h3><ul class="dsa41-list">{{#each system.automaticDisadvantages}}<li>{{this}}</li>{{/each}}</ul></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.recommendedAdvantages"}}</h3><ul class="dsa41-list">{{#each system.recommendedAdvantages}}<li>{{this}}</li>{{/each}}</ul><h3>{{localize "DSA41.Species.recommendedDisadvantages"}}</h3><ul class="dsa41-list">{{#each system.recommendedDisadvantages}}<li>{{this}}</li>{{/each}}</ul></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Species.unsuitableAdvantages"}}</h3><ul class="dsa41-list">{{#each system.unsuitableAdvantages}}<li>{{this}}</li>{{/each}}</ul><h3>{{localize "DSA41.Species.unsuitableDisadvantages"}}</h3><ul class="dsa41-list">{{#each system.unsuitableDisadvantages}}<li>{{this}}</li>{{/each}}</ul></section>
        </div>
        {{/if}}
    {{/if}}

    {{#if isCulture}}
