        </div>
        <div class="dsa41-two-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.allowedProfessions"}}</h3><ul class="dsa41-list">{{#each system.allowedProfessions}}<li>{{this}}</li>{{/each}}</ul></section>
            <section class="dsa41-panel"><h3>{{localize "DSA41.Culture.automaticAdvantages"}}</h3><ul class="dsa41-list">{{#each system.automaticAdvantages}}<li>{{this}}</li>{{/each}}</ul><h3>{{localize "DSA41.Culture.automaticDisadvantages"}}</h3><ul class="dsa41-list">{{#each system.automaticDisadvantages}}<li>{{this}}</li>{{/each}}</ul></section>
        </div>
        <div class="dsa41-three-column">
