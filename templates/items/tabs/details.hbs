            <section class="dsa41-panel"><h3>{{localize "DSA41.Profession.recommendedAdvantages"}}</h3><ul class="dsa41-list">{{#each system.recommendedAdvantages}}<li>{{this}}</li>{{/each}}</ul><h3>{{localize "DSA41.Profession.recommendedDisadvantages"}}</h3><ul class="dsa41-list">{{#each system.recommendedDisadvantages}}<li>{{this}}</li>{{/each}}</ul><h3>{{localize "DSA41.Profession.unsuitableAdvantages"}}</h3><ul class="dsa41-list">{{#each system.unsuitableAdvantages}}<li>{{this}}</li>{{/each}}</ul><h3>{{localize "DSA41.Profession.unsuitableDisadvantages"}}</h3><ul class="dsa41-list">{{#each system.unsuitableDisadvantages}}<li>{{this}}</li>{{/each}}</ul></section>
