{{#if isSpecies}}
<section class="dsa41-tab-panel {{#if (eq activeTab 'details')}}is-hidden{{/if}}">
    {{#if isEditMode}}
    <div class="dsa41-two-column">
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Sheet.description"}}</h3>
            <textarea name="system.description">{{system.description}}</textarea>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.originDistribution"}}</h3>
            <textarea name="system.originDistribution">{{system.originDistribution}}</textarea>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.appearanceDescription"}}</h3>
            <textarea name="system.appearance">{{system.appearance}}</textarea>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.identifier"}}</h3>
            <input name="system.identifier" type="text" value="{{system.identifier}}" />
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.reproductionAndAging"}}</h3>
            <textarea name="system.reproductionAndAging">{{system.reproductionAndAging}}</textarea>
        </section>
    </div>

    <div class="dsa41-two-column">
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.hairColor"}}</h3>
            <small>{{localize "DSA41.Species.tableHint"}}</small>
            <textarea name="species.hairColorsText">{{species.hairColorsText}}</textarea>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.eyeColor"}}</h3>
            <small>{{localize "DSA41.Species.tableHint"}}</small>
            <textarea name="species.eyeColorsText">{{species.eyeColorsText}}</textarea>
        </section>
    </div>

    <div class="dsa41-two-column">
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.height"}}</h3>
            <div class="dsa41-stats-grid">
                <label><span>{{localize "DSA41.Species.base"}}</span><input name="system.height.base" type="text" value="{{system.height.base}}" /></label>
                <label><span>{{localize "DSA41.Species.diceCount"}}</span><input name="system.height.diceCount" type="number" value="{{system.height.diceCount}}" /></label>
                <label><span>{{localize "DSA41.Species.diceFaces"}}</span><input name="system.height.diceFaces" type="number" value="{{system.height.diceFaces}}" /></label>
                <label><span>{{localize "DSA41.Species.step"}}</span><input name="system.height.step" type="text" value="{{system.height.step}}" /></label>
                <label><span>{{localize "DSA41.Species.unit"}}</span><input name="system.height.unit" type="text" value="{{system.height.unit}}" /></label>
                <label><span>{{localize "DSA41.Species.formula"}}</span><input name="system.height.formula" type="text" value="{{system.height.formula}}" /></label>
            </div>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.weight"}}</h3>
            <div class="dsa41-stats-grid">
                <label><span>{{localize "DSA41.Species.formula"}}</span><input name="system.weight.formula" type="text" value="{{system.weight.formula}}" /></label>
                <label><span>{{localize "DSA41.Species.unit"}}</span><input name="system.weight.unit" type="text" value="{{system.weight.unit}}" /></label>
            </div>
        </section>
    </div>

    <div class="dsa41-two-column">
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.characteristicModifiers"}}</h3>
            <div class="dsa41-stats-grid">
                {{#each system.modifiers.characteristics as |value key|}}
                <label>
                    <span>{{localize (lookup ../config.characteristics key)}}</span>
                    <input name="system.modifiers.characteristics.{{key}}" type="number" value="{{value}}" />
                </label>
                {{/each}}
            </div>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.otherModifiers"}}</h3>
            <div class="dsa41-stats-grid">
                <label><span>{{localize "DSA41.Species.lifePointsModifier"}}</span><input name="system.modifiers.lifePoints" type="number" value="{{system.modifiers.lifePoints}}" /></label>
                <label><span>{{localize "DSA41.Species.enduranceModifier"}}</span><input name="system.modifiers.endurance" type="number" value="{{system.modifiers.endurance}}" /></label>
                <label><span>{{localize "DSA41.Species.astralPointsModifier"}}</span><input name="system.modifiers.astralPoints" type="number" value="{{system.modifiers.astralPoints}}" /></label>
                <label><span>{{localize "DSA41.Species.magicResistanceModifier"}}</span><input name="system.modifiers.magicResistance" type="number" value="{{system.modifiers.magicResistance}}" /></label>
            </div>
        </section>
    </div>

    <div class="dsa41-two-column">
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.automaticAdvantages"}}</h3>
            <textarea name="species.automaticAdvantagesText">{{species.automaticAdvantagesText}}</textarea>
            <h3>{{localize "DSA41.Species.automaticDisadvantages"}}</h3>
            <textarea name="species.automaticDisadvantagesText">{{species.automaticDisadvantagesText}}</textarea>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.recommendedAdvantages"}}</h3>
            <textarea name="species.recommendedAdvantagesText">{{species.recommendedAdvantagesText}}</textarea>
            <h3>{{localize "DSA41.Species.recommendedDisadvantages"}}</h3>
            <textarea name="species.recommendedDisadvantagesText">{{species.recommendedDisadvantagesText}}</textarea>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.unsuitableAdvantages"}}</h3>
            <textarea name="species.unsuitableAdvantagesText">{{species.unsuitableAdvantagesText}}</textarea>
            <h3>{{localize "DSA41.Species.unsuitableDisadvantages"}}</h3>
            <textarea name="species.unsuitableDisadvantagesText">{{species.unsuitableDisadvantagesText}}</textarea>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.allowedCultures"}}</h3>
            <small>{{localize "DSA41.Species.listHint"}}</small>
            <textarea name="species.allowedCulturesText">{{species.allowedCulturesText}}</textarea>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.grantedTalents"}}</h3>
            <small>{{localize "DSA41.Species.talentHint"}}</small>
            <textarea name="species.grantedTalentsText">{{species.grantedTalentsText}}</textarea>
        </section>
    </div>
    {{else}}
    <div class="dsa41-species-description">
        <section class="dsa41-panel dsa41-species-lead">
            <h3>{{localize "DSA41.Sheet.description"}}</h3>
            <p>{{system.description}}</p>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.originDistribution"}}</h3>
            <p>{{system.originDistribution}}</p>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.appearanceDescription"}}</h3>
            <p>{{system.appearance}}</p>
        </section>
        {{#if species.hasReproductionAndAging}}
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.reproductionAndAging"}}</h3>
            <p>{{species.reproductionAndAging}}</p>
        </section>
        {{/if}}
    </div>

    <div class="dsa41-species-divider"></div>

    <div class="dsa41-two-column dsa41-species-pair">
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.hairColor"}}</h3>
            <table class="dsa41-species-table">
                <tbody>
                    {{#each species.hairColors}}
                    <tr><td class="range">{{min}}-{{max}}</td><td>{{label}}</td></tr>
                    {{/each}}
                </tbody>
            </table>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.eyeColor"}}</h3>
            <table class="dsa41-species-table">
                <tbody>
                    {{#each species.eyeColors}}
                    <tr><td class="range">{{min}}-{{max}}</td><td>{{label}}</td></tr>
                    {{/each}}
                </tbody>
            </table>
        </section>
    </div>

    <div class="dsa41-two-column dsa41-species-pair">
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.height"}}</h3>
            <p>{{species.heightText}}</p>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.weight"}}</h3>
            <p>{{species.weightText}}</p>
        </section>
    </div>

    <section class="dsa41-panel">
        <h3>{{localize "DSA41.Species.characteristicModifiers"}}</h3>
        <div class="dsa41-species-stat-grid">
            {{#each species.characteristicModifierBoxes as |modifier|}}
            <div class="dsa41-species-stat-box" title="{{modifier.label}}">
                <span class="abbr">{{modifier.abbr}}</span>
                <span class="value">{{modifier.value}}</span>
            </div>
            {{/each}}
        </div>

        <h3>{{localize "DSA41.Species.otherModifiers"}}</h3>
        <ul class="dsa41-species-inline-list">
            {{#each species.scalarModifiers}}
            <li><strong>{{label}}:</strong> {{value}}</li>
            {{/each}}
        </ul>
    </section>

    <section class="dsa41-panel">
        <h3>{{localize "DSA41.Species.grantedTalents"}}</h3>
        <div class="dsa41-species-talent-groups">
            {{#each species.talentGroups as |group|}}
            <section class="dsa41-species-talent-group">
                <h4>{{localize group.label}}</h4>
                <table class="dsa41-species-table">
                    <tbody>
                        {{#each group.entries}}
                        <tr><td>{{name}}</td><td class="range">{{value}}</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </section>
            {{/each}}
        </div>
    </section>

    <div class="dsa41-three-column dsa41-species-pair">
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.automaticAdvantages"}}</h3>
            <ul class="dsa41-list">{{#each species.automaticAdvantages}}<li>{{this}}</li>{{/each}}</ul>
            <h3>{{localize "DSA41.Species.automaticDisadvantages"}}</h3>
            <ul class="dsa41-list">{{#each species.automaticDisadvantages}}<li>{{this}}</li>{{/each}}</ul>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.recommendedAdvantages"}}</h3>
            <ul class="dsa41-list">{{#each species.recommendedAdvantages}}<li>{{this}}</li>{{/each}}</ul>
            <h3>{{localize "DSA41.Species.recommendedDisadvantages"}}</h3>
            <ul class="dsa41-list">{{#each species.recommendedDisadvantages}}<li>{{this}}</li>{{/each}}</ul>
        </section>
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Species.unsuitableAdvantages"}}</h3>
            <ul class="dsa41-list">{{#each species.unsuitableAdvantages}}<li>{{this}}</li>{{/each}}</ul>
            <h3>{{localize "DSA41.Species.unsuitableDisadvantages"}}</h3>
            <ul class="dsa41-list">{{#each species.unsuitableDisadvantages}}<li>{{this}}</li>{{/each}}</ul>
        </section>
    </div>

    <section class="dsa41-panel">
        <h3>{{localize "DSA41.Species.allowedCultures"}}</h3>
        <ul class="dsa41-species-inline-list">
            {{#each species.allowedCultures}}<li>{{this}}</li>{{/each}}
        </ul>
    </section>
    </section>
{{else}}
<section class="dsa41-tab-panel {{#unless (eq activeTab 'description')}}is-hidden{{/unless}}">
    {{#if isComplexSheet}}
        {{#if isEditMode}}
        <div class="dsa41-two-column">
            <section class="dsa41-panel">
                <h3>{{localize "DSA41.Sheet.description"}}</h3>
                <textarea name="system.description">{{system.description}}</textarea>
            </section>
            {{#if isCulture}}
            <section class="dsa41-panel">
                <h3>{{localize "DSA41.Culture.livingArea"}}</h3>
                <textarea name="system.livingArea">{{system.livingArea}}</textarea>
            </section>
            {{/if}}
            {{#if isProfession}}
            <section class="dsa41-panel">
                <h3>{{localize "DSA41.Profession.requirements"}}</h3>
                <textarea name="profession.requirementsText">{{profession.requirementsText}}</textarea>
            </section>
            {{/if}}
        </div>
        {{else}}
        <div class="dsa41-two-column">
            <section class="dsa41-panel"><h3>{{localize "DSA41.Sheet.description"}}</h3><p>{{system.description}}</p></section>
            {{#if isCulture}}<section class="dsa41-panel"><h3>{{localize "DSA41.Culture.livingArea"}}</h3><p>{{system.livingArea}}</p></section>{{/if}}
            {{#if isProfession}}<section class="dsa41-panel"><h3>{{localize "DSA41.Profession.requirements"}}</h3><ul class="dsa41-list">{{#each system.requirements}}<li>{{this}}</li>{{/each}}</ul></section>{{/if}}
        </div>
        {{/if}}
    {{else}}
    <section class="dsa41-panel">
        <h3>{{localize "DSA41.Sheet.description"}}</h3>
        <textarea name="system.description">{{system.description}}</textarea>
    </section>
    {{/if}}
</section>
{{/if}}
