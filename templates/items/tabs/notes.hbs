<section class="dsa41-tab-panel {{#unless (eq activeTab 'notes')}}is-hidden{{/unless}}">
    <section class="dsa41-panel">
        <h3>{{localize "DSA41.Sheet.notes"}}</h3>
        {{#if isComplexSheet}}
            {{#if isEditMode}}
            <textarea name="system.notes">{{system.notes}}</textarea>
            {{else}}
            <p>{{system.notes}}</p>
            {{/if}}
        {{else}}
        <textarea name="system.notes">{{system.notes}}</textarea>
        {{/if}}
    </section>
</section>
