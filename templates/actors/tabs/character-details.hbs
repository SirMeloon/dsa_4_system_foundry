<section class="dsa41-tab-panel {{#unless (eq activeTab 'details')}}is-hidden{{/unless}}">
    <div class="dsa41-panel">
        <h3>{{localize "DSA41.Tab.characteristics"}}</h3>
        <div class="dsa41-stats-grid">
            {{#each system.characteristics as |char key|}}
            <label class="dsa41-stat">
                <span>{{localize (lookup ../config.characteristics key)}}</span>
                <input name="system.characteristics.{{key}}.value" type="number" value="{{char.value}}" />
            </label>
            {{/each}}
        </div>
    </div>

    <div class="dsa41-two-column">
        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Tab.progress"}}</h3>
            <label>{{localize "DSA41.Character.experience"}}<input name="system.experience" type="number" value="{{system.experience}}" /></label>
        </section>

        <section class="dsa41-panel">
            <h3>{{localize "DSA41.Tab.combat"}}</h3>
            <div class="dsa41-stack">
                <label>{{localize "DSA41.Character.initiativeBase"}}<input name="system.combat.initiativeBase" type="number" value="{{system.combat.initiativeBase}}" /></label>
                <label>{{localize "DSA41.Character.attackBase"}}<input name="system.combat.attackBase" type="number" value="{{system.combat.attackBase}}" /></label>
                <label>{{localize "DSA41.Character.parryBase"}}<input name="system.combat.parryBase" type="number" value="{{system.combat.parryBase}}" /></label>
            </div>
        </section>
    </div>
</section>
