<aside class="dsa41-sidebar">
    <section class="dsa41-panel">
        <h3>{{localize "DSA41.Tab.resources"}}</h3>
        <div class="dsa41-stack">
            <label>{{localize "DSA41.Character.lifePoints"}}<input name="system.resources.lifePoints.value" type="number" value="{{system.resources.lifePoints.value}}" /></label>
            <label>{{localize "DSA41.Character.endurance"}}<input name="system.resources.endurance.value" type="number" value="{{system.resources.endurance.value}}" /></label>
            <label>{{localize "DSA41.Character.astralPoints"}}<input name="system.resources.astralPoints.value" type="number" value="{{system.resources.astralPoints.value}}" /></label>
            <label>{{localize "DSA41.Character.karmaPoints"}}<input name="system.resources.karmaPoints.value" type="number" value="{{system.resources.karmaPoints.value}}" /></label>
        </div>
    </section>

    <section class="dsa41-panel">
        <h3>{{localize "DSA41.Tab.appearance"}}</h3>
        <div class="dsa41-stack">
            <label>{{localize "DSA41.Character.hairColor"}}<input name="system.appearance.hairColor" type="text" value="{{system.appearance.hairColor}}" /></label>
            <label>{{localize "DSA41.Character.eyeColor"}}<input name="system.appearance.eyeColor" type="text" value="{{system.appearance.eyeColor}}" /></label>
            <label>{{localize "DSA41.Character.height"}}<input name="system.appearance.height" type="text" value="{{system.appearance.height}}" /></label>
            <label>{{localize "DSA41.Character.weight"}}<input name="system.appearance.weight" type="text" value="{{system.appearance.weight}}" /></label>
        </div>
    </section>
</aside>
